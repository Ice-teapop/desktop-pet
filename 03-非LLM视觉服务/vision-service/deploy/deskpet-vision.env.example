# DeskPet 非 LLM 视觉服务 —— 环境变量模板
#
# 用法：复制到服务器 /etc/deskpet-vision.env，填入真实值，并 chmod 600。
#   cp deploy/deskpet-vision.env.example /etc/deskpet-vision.env
#   chmod 600 /etc/deskpet-vision.env
#
# 这个 .example 文件可以进 git；真实的 /etc/deskpet-vision.env 绝不要进 git。

# 鉴权 token（必填）—— 客户端与服务端两侧需配置一致。
# 换成你自己的强随机串，例如用： openssl rand -hex 32
DESKPET_VISION_TOKEN=请替换为你自己的强随机token
